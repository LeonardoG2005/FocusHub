NODE_ENV=production
PORT=3000
FRONTEND_URL=https://REPLACE_WITH_FRONTEND_URL
ENABLE_SWAGGER=true
JWT_SECRET=replace_with_a_long_random_secret

# Neon/PostgreSQL connection string (recommended)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Database options: sqlite or postgres (fallback when DATABASE_URL is empty)
DB_TYPE=postgres
DB_SYNCHRONIZE=true
DB_LOGGING=false

# PostgreSQL settings (used when DB_TYPE=postgres and DATABASE_URL is empty)
DB_HOST=your-db-host
DB_PORT=5432
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name
DB_SSL=true

# SQLite fallback (used when DB_TYPE=sqlite)
SQLITE_PATH=focushub.db
